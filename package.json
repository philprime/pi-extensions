{
  "name": "@philprime/pi-extensions",
  "version": "0.1.0",
  "private": true,
  "description": "Personal extensions for the Pi coding agent",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@earendil-works/pi-coding-agent": "0.82.0",
    "@types/node": "26.1.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "pi": {
    "extensions": [
      "./extensions/permissions.ts",
      "./extensions/run.ts"
    ]
  }
}
